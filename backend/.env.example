# Copy this file to backend/.env for local development.

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
JWT_SECRET=replace-with-a-random-string-minimum-32-characters

# Optional SMTP settings for background email notifications.
# Leave these blank if email notification is not needed locally.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
